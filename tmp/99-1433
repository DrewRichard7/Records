def update_entry(
        session: Session,
        entry_id: int,
        *,
        category_name: str,
        title: str,
        creator: str,
        tags: str = "",
        notes: str = "",
        ) -> Entry | None:
    entry = session.get(Entry, entry_id)
    if entry is None:
        return None

    entry.category_name = category_name
    entry.title = title.strip()
    entry.creator = creator.strip()
    entry.tags = tags.strip()
    entry.notes = notes.strip()
    entry.updated_at = utc_now()

    session.add(entry)
    session.commit()
    session.refresh(entry)
    return entry
